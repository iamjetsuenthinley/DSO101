pipeline {
    agent any
    tools {
        nodejs 'NodeJS'
    }
    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/yourusername/your-repo.git',
                    credentialsId: 'github-creds'
            }
        }

        stage('Install Backend') {
            steps {
                sh 'cd assignment2/backend && npm install'
            }
        }

        stage('Install Frontend') {
            steps {
                sh 'cd assignment2/frontend && npm install'
            }
        }

        stage('Build Frontend') {
            steps {
                sh 'cd assignment2/frontend && npm run build'
            }
        }

        stage('Test Backend') {
            steps {
                sh 'cd assignment2/backend && npm test'
            }
            post {
                always {
                    junit 'assignment2/backend/junit.xml'
                }
            }
        }

        stage('Deploy') {
            steps {
                script {
                    docker.build('yourdockerhubusername/todo-app:latest')
                    docker.withRegistry('https://registry.hub.docker.com', 'docker-hub-creds') {
                        docker.image('yourdockerhubusername/todo-app:latest').push()
                    }
                }
            }
        }
    }
}